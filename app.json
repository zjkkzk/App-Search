{
  "expo": {
    "name": "开源应用商店",
    "slug": "open-app-store",
    "version": "1.0.134",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "openappstore",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F6F8"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.miaoda.openappstore",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F6F8"
      },
      "predictiveBackGestureEnabled": true,
      "versionCode": 2,
      "package": "com.miaoda.openappstore",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-sqlite",
      "expo-font",
      "expo-system-ui",
      "expo-secure-store",
      "expo-web-browser",
      "expo-image",
      "expo-file-system",
      "expo-sharing",
      "expo-splash-screen",
      "@react-native-async-storage/expo-with-async-storage",
      "./plugins/withAndroidABIFilter"
    ],
    "router": {
      "root": "src"
    },
    "experiments": {
      "baseUrl": "/App-Search",
      "typedRoutes": true
    }
  }
}