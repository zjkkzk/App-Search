{
  "expo": {
    "name": "开源应用商店",
    "slug": "open-app-store",
    "version": "1.0.455",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "openappstore",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FCFDFC"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.miaoda.openappstore",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true,
        "UIBackgroundModes": [
          "fetch",
          "processing"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F6F8"
      },
      "predictiveBackGestureEnabled": true,
      "versionCode": 1,
      "package": "com.miaoda.openappstore",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.REQUEST_INSTALL_PACKAGES",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-sqlite",
      "expo-font",
      "expo-system-ui",
      "expo-secure-store",
      "expo-web-browser",
      "expo-image",
      "expo-file-system",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FCFDFC",
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-notifications",
      "@react-native-async-storage/expo-with-async-storage",
      "./plugins/withAndroidSplashFix",
      "./plugins/withAndroidDoubleBackExit",
      "./plugins/withAndroidABIFilter",
      "./plugins/withAndroidInstallPackages"
    ],
    "router": {
      "root": "src"
    },
    "experiments": {
      "baseUrl": "/App-Search",
      "typedRoutes": true
    }
  }
}